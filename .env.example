# ──────────────────────────────────────────────
# Contato — rota POST /api/contact
# ──────────────────────────────────────────────

# URL de um webhook (ex.: Make, n8n, Zapier) que receberá os dados do formulário de contato.
# Se não for definido, o envio ainda retornará sucesso (sem reencaminhar).
CONTACT_WEBHOOK_URL=

# Token de autenticação Bearer opcional para o webhook acima.
CONTACT_WEBHOOK_AUTH_TOKEN=

# ──────────────────────────────────────────────
# Pagamento — rota POST /api/payment
# ──────────────────────────────────────────────
# Formato: PAYMENT_LINK_<PLANO>_<METODO>
# Planos:  LANDING_EXPRESS | FUNNEL_CRM | AUTOMATION_PRO | ECOMMERCE_GROWTH | PLATFORM_CUSTOM
# Métodos: PIX | CARD | BOLETO | RECURRING
#
# Exemplos:
PAYMENT_LINK_LANDING_EXPRESS_PIX=https://link-de-pagamento.com/landing-pix
PAYMENT_LINK_LANDING_EXPRESS_CARD=https://link-de-pagamento.com/landing-card
PAYMENT_LINK_LANDING_EXPRESS_BOLETO=https://link-de-pagamento.com/landing-boleto
PAYMENT_LINK_LANDING_EXPRESS_RECURRING=https://link-de-pagamento.com/landing-recorrencia

PAYMENT_LINK_FUNNEL_CRM_PIX=https://link-de-pagamento.com/funnel-pix
PAYMENT_LINK_FUNNEL_CRM_CARD=https://link-de-pagamento.com/funnel-card
PAYMENT_LINK_FUNNEL_CRM_BOLETO=https://link-de-pagamento.com/funnel-boleto
PAYMENT_LINK_FUNNEL_CRM_RECURRING=https://link-de-pagamento.com/funnel-recorrencia

PAYMENT_LINK_AUTOMATION_PRO_PIX=https://link-de-pagamento.com/automation-pix
PAYMENT_LINK_AUTOMATION_PRO_CARD=https://link-de-pagamento.com/automation-card
PAYMENT_LINK_AUTOMATION_PRO_BOLETO=https://link-de-pagamento.com/automation-boleto
PAYMENT_LINK_AUTOMATION_PRO_RECURRING=https://link-de-pagamento.com/automation-recorrencia

PAYMENT_LINK_ECOMMERCE_GROWTH_PIX=https://link-de-pagamento.com/ecommerce-pix
PAYMENT_LINK_ECOMMERCE_GROWTH_CARD=https://link-de-pagamento.com/ecommerce-card
PAYMENT_LINK_ECOMMERCE_GROWTH_BOLETO=https://link-de-pagamento.com/ecommerce-boleto
PAYMENT_LINK_ECOMMERCE_GROWTH_RECURRING=https://link-de-pagamento.com/ecommerce-recorrencia

PAYMENT_LINK_PLATFORM_CUSTOM_PIX=https://link-de-pagamento.com/platform-pix
PAYMENT_LINK_PLATFORM_CUSTOM_CARD=https://link-de-pagamento.com/platform-card
PAYMENT_LINK_PLATFORM_CUSTOM_BOLETO=https://link-de-pagamento.com/platform-boleto
PAYMENT_LINK_PLATFORM_CUSTOM_RECURRING=https://link-de-pagamento.com/platform-recorrencia
